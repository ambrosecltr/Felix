{
  "name": "felix",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
    "dev:desktop": "turbo run dev --filter=@felix/desktop",
    "setup:runtime": "node scripts/fetch-node-runtime.mjs",
    "setup:bun": "node scripts/fetch-bun-runtime.mjs",
    "bundle:agent": "node scripts/bundle-agent.mjs",
    "make:icon": "node scripts/make-app-icon.mjs",
    "package:desktop": "cd apps/desktop && bun run package"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
